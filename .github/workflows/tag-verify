name: Verify Tag Source Branch

on:
  push:
    tags:
      - '*'

jobs:
  verify-tag:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout code with full history
        uses: actions/checkout@v4
        with:
          fetch-depth: 0

      - name: Check if tag is on main branch
        run: |
          TAG_COMMIT=${{ github.sha }}
          echo "Checking if commit $TAG_COMMIT belongs to main branch..."
          
          # 显式拉取最新的远程 main 分支，确保本地缓存完整
          git fetch origin main:main || true
          
          # 验证该 commit 是否在 main 分支的历史树中
          if git merge-base --is-ancestor "$TAG_COMMIT" origin/main; then
            echo "Success: This tag is based on the main branch."
          else
            echo "::error::Tags can only be created and pushed from the 'main' branch!"
            exit 1
          fi
